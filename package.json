{
  "name": "frontend",
  "version": "1.0.0",
  "description": "Frontend template with Vite, Vue Islands, SCSS and Handlebars",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:watch": "npm-run-all --parallel dev images:watch",
    "build": "npm run images:convert && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "images:convert": "node scripts/convert-images.js",
    "images:watch": "node scripts/convert-images.js --watch"
  },
  "keywords": [
    "vite",
    "vue",
    "islands",
    "scss",
    "handlebars"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "fast-glob": "^3.3.3",
    "npm-run-all": "^4.1.5",
    "sass": "^1.97.3",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-handlebars": "^2.0.0",
    "vite-plugin-svg-icons": "^2.0.1"
  }
}
